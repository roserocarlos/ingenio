# =============================================================================
# Ingenio+ — Variables de entorno v11
# Copiar a .env y completar antes de levantar el stack
# NUNCA subir .env al repositorio
# =============================================================================

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=America/Bogota

# ── OpenRemote ────────────────────────────────────────────────────────────────
OR_HOSTNAME=ingenioplus.local
OR_ADMIN_PASSWORD=linuxxl2

# ── EMQX ──────────────────────────────────────────────────────────────────────
EMQX_DASHBOARD_USER=ingenio
EMQX_DASHBOARD_PASSWORD=linuxxl2

# ── InfluxDB ──────────────────────────────────────────────────────────────────
INFLUXDB_ADMIN_USER=ingenio
INFLUXDB_ADMIN_PASSWORD=linuxxl2
INFLUXDB_ORG=agrosensor
INFLUXDB_BUCKET=sensores
INFLUXDB_RETENTION=0
# Token se obtiene y guarda automáticamente con: bash scripts/init_influxdb.sh
INFLUXDB_TOKEN=

# ── Node-RED ──────────────────────────────────────────────────────────────────
NODE_RED_CREDENTIAL_SECRET=ingenio

# ── Alertas (opcional) ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Caddy ─────────────────────────────────────────────────────────────────────
CADDY_EMAIL=ingenio.plus.contacto@gmail.com
