# =============================================================================
# Ingenio+ — Caddyfile v11
#
# MODO LOCAL (activo): mDNS ingenioplus.local sin TLS
# MODO NUBE (comentado): ingenio.plus con TLS automático via Let's Encrypt
#
# Para activar modo nube:
#   1. Comentar el bloque :80
#   2. Descomentar los bloques de dominios
#   3. docker compose restart caddy
# =============================================================================

# ── MODO LOCAL — proxy unificado :80 ──────────────────────────────────────────
:80 {
    # OpenRemote Manager — ruta principal
    @auth path /auth/*
    handle @auth {
        reverse_proxy openremote-keycloak:8080
    }

    # Todo lo demás → OpenRemote Manager
    handle {
        reverse_proxy openremote-manager:8080
    }
}

# ── MODO NUBE (comentado — activar cuando haya dominio público) ──────────────
# ingenio.plus, www.ingenio.plus {
#     reverse_proxy nginx:80
# }
#
# openremote.ingenio.plus {
#     reverse_proxy openremote-manager:8080
# }
#
