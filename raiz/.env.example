# =============================================================================
# Ingenio+ — Plan Raíz · Variables de entorno
# Copiar a .env y editar antes de levantar el stack
# NUNCA subir .env al repositorio
# =============================================================================

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=America/Bogota

# ── Mosquitto (autenticación) ─────────────────────────────────────────────────
MQTT_USER=ingenio
MQTT_PASSWORD=linuxxl2

# ── InfluxDB ──────────────────────────────────────────────────────────────────
INFLUXDB_ADMIN_USER=ingenio
INFLUXDB_ADMIN_PASSWORD=linuxxl2
INFLUXDB_ORG=agrosensor
INFLUXDB_BUCKET=sensores
# Token fijo — mismo esquema que Plan Cosecha para reusar dashboard sin cambios
INFLUXDB_TOKEN=ingenio-raiz-token-cambiar-en-produccion

# ── Node-RED ──────────────────────────────────────────────────────────────────
# Secreto fijo — evita el bug de flows_cred.json corrupto entre reimports
NODE_RED_CREDENTIAL_SECRET=ingenio-raiz-secret

# ── Grafana (solo panel admin técnico) ────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=linuxxl2
